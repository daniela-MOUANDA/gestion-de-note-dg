# Configuration Supabase
SUPABASE_URL=https://kfzxqijezruswblokrdn.supabase.co
SUPABASE_ANON_KEY=key
SUPABASE_SERVICE_ROLE_KEY=service_key

DATABASE_URL="url"
JWT_SECRET="url"
JWT_EXPIRES_IN="24h"
# URL exacte du front (génération du QR sur les bulletins). En production : https://votre-domaine
FRONTEND_URL=http://localhost:5173
# Optionnel : jetons de vérification des bulletins (sinon JWT_SECRET est réutilisé)
# BULLETIN_VERIFY_SECRET=
VITE_API_URL="http://localhost:3000/api"
PORT=3000

# E-mails (étudiants, coordinateurs) — mettre le mot de passe d'application entre guillemets s'il contient des espaces
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# Si ETIMEDOUT sur 587 (pare-feu / FAI), essayez plutôt le port SSL :
# SMTP_PORT=465
# SMTP_USER=votre.email@gmail.com
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# SMTP_FROM_NAME=INPTIC - Plateforme pedagogique
# Si timeout bizarre vers Gmail, forcer IPv4 d'abord (Node 17+) :
# SMTP_IPV4_FIRST=1